@model KOL_KOC_TAAA.ViewModels.KolProfileEditViewModel
@using KOL_KOC_TAAA.Models
@using KOL_KOC_TAAA.ViewModels
@{
    Layout = "_LayoutLuxury";
    ViewData["Title"] = "Chỉnh sửa hồ sơ - Creator Studio";
    var socialAccounts = ViewBag.SocialAccounts as List<KolSocialAccount> ?? new List<KolSocialAccount>();
    var portfolios = ViewBag.Portfolios as List<KolPortfolio> ?? new List<KolPortfolio>();
    var rateCards = ViewBag.RateCards as List<RateCard> ?? new List<RateCard>();
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="position-fixed top-0 start-50 translate-middle-x p-3" style="z-index:2000;top:1.5rem!important;">
        <div class="toast show align-items-center border-0 text-white" style="background:var(--lux-accent-gold);border-radius:12px;" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-semibold"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]</div>
            </div>
        </div>
    </div>
}

<div class="container py-5">

    <!-- Page header -->
    <div class="mb-5" data-reveal="fade-up">
        <a asp-action="Index" class="lux-link small mb-3 d-inline-block"><i class="bi bi-arrow-left me-1"></i> Quay lại Dashboard</a>
        <h1 class="lux-h1">Chỉnh sửa <span class="text-gradient-gold">Hồ sơ</span></h1>
        <p class="text-muted">Cập nhật thông tin để tăng khả năng kết nối với các thương hiệu.</p>
    </div>

    <div class="row g-4">

        <!-- LEFT COLUMN: Avatar + Quick Nav -->
        <div class="col-lg-3" data-reveal="fade-left">
            <!-- Avatar preview card -->
            <div class="lux-surface p-4 text-center mb-4 sticky-top" style="top:90px;">
                <div class="position-relative d-inline-block mb-3">
                    <img id="avatarPreview"
                         src="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.FullName ?? "KOL") + "&background=C9A84C&color=fff&size=160" : Model.AvatarUrl)"
                         alt="Avatar"
                         class="rounded-circle border border-2"
                         style="width:110px;height:110px;object-fit:cover;border-color:var(--lux-accent-gold)!important;">
                    <span class="position-absolute bottom-0 end-0 bg-dark text-white rounded-circle d-flex align-items-center justify-content-center"
                          style="width:28px;height:28px;cursor:pointer;" onclick="document.getElementById('AvatarUrl').focus()">
                        <i class="bi bi-camera-fill" style="font-size:.7rem;"></i>
                    </span>
                </div>
                <div class="fw-semibold lux-h4 mb-1">@(Model.FullName ?? "Chưa đặt tên")</div>
                <div class="text-gold small mb-3">@(Model.InfluencerType ?? "KOL") Influencer</div>

                <!-- Section nav pills -->
                <div class="d-flex flex-column gap-2 text-start">
                    <a href="#section-identity" class="ep-nav-link active"><i class="bi bi-person-circle me-2"></i>Danh tính</a>
                    <a href="#section-profile" class="ep-nav-link"><i class="bi bi-card-text me-2"></i>Hồ sơ cá nhân</a>
                    <a href="#section-social" class="ep-nav-link"><i class="bi bi-share me-2"></i>Mạng xã hội</a>
                    <a href="#section-portfolio" class="ep-nav-link"><i class="bi bi-images me-2"></i>Portfolio</a>
                    <a href="#section-services" class="ep-nav-link"><i class="bi bi-tags me-2"></i>Dịch vụ & Báo giá</a>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: All edit sections -->
        <div class="col-lg-9">

            <form asp-action="EditProfile" method="post" id="mainProfileForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

            <!-- ===== SECTION 1: IDENTITY ===== -->
            <section id="section-identity" class="lux-surface p-4 mb-4" data-reveal="fade-up">
                <h5 class="lux-cap text-gold mb-4"><i class="bi bi-person-circle me-2"></i>Danh tính & Ảnh đại diện</h5>

                    <div class="row g-3">
                        <!-- Avatar Upload -->
                        <div class="col-12">
                            <label class="form-label lux-cap mb-1 small">Upload ảnh đại diện</label>
                            <input type="file" name="AvatarFile" id="AvatarFile" accept="image/*"
                                   class="form-control lux-input" onchange="previewAvatar(this)">
                            <div class="form-text text-muted">JPG, PNG, WEBP — tối đa 10MB. Ảnh hiện tại sẽ được giữ nếu không chọn ảnh mới.</div>
                        </div>

                        <!-- Full Name -->
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label lux-cap mb-1 small"></label>
                            <input asp-for="FullName" class="lux-input w-100" placeholder="Tên hiển thị công khai">
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <!-- Contact Email (public) -->
                        <div class="col-md-6">
                            <label asp-for="ContactEmail" class="form-label lux-cap mb-1 small"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-secondary text-muted"><i class="bi bi-envelope"></i></span>
                                <input asp-for="ContactEmail" class="lux-input" placeholder="email@example.com">
                            </div>
                            <div class="form-text text-muted">Email này sẽ hiển thị trên trang hồ sơ công khai.</div>
                            <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                        </div>

                        <!-- InfluencerType + MinBudget -->
                        <div class="col-md-6">
                            <label asp-for="InfluencerType" class="form-label lux-cap mb-1 small"></label>
                            <select asp-for="InfluencerType" class="lux-input w-100">
                                <option value="Nano">Nano (1K–10K followers)</option>
                                <option value="Micro">Micro (10K–100K)</option>
                                <option value="Macro">Macro (100K–1M)</option>
                                <option value="Mega">Mega / Celeb (1M+)</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="MinBudget" class="form-label lux-cap mb-1 small"></label>
                            <div class="input-group">
                                <input asp-for="MinBudget" class="lux-input" placeholder="500000">
                                <span class="input-group-text bg-transparent border-secondary text-muted">₫</span>
                            </div>
                            <span asp-validation-for="MinBudget" class="text-danger small"></span>
                        </div>

                    </div>
            </section>

            <!-- ===== SECTION 2: PROFILE INFO ===== -->
            <section id="section-profile" class="lux-surface p-4 mb-4" data-reveal="fade-up">
                <h5 class="lux-cap text-gold mb-4"><i class="bi bi-card-text me-2"></i>Hồ sơ cá nhân</h5>

                <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Bio" class="form-label lux-cap mb-1 small"></label>
                            <textarea asp-for="Bio" class="lux-input w-100" rows="5"
                                      placeholder="Giới thiệu bản thân, phong cách sáng tạo và lĩnh vực nổi bật của bạn..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label lux-cap mb-1 small"></label>
                            <select asp-for="Gender" class="lux-input w-100">
                                <option value="">-- Chọn --</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác / Không tiết lộ</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Dob" class="form-label lux-cap mb-1 small"></label>
                            <input asp-for="Dob" type="date" class="lux-input w-100">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LocationCity" class="form-label lux-cap mb-1 small"></label>
                            <input asp-for="LocationCity" class="lux-input w-100" placeholder="e.g. TP. Hồ Chí Minh">
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LocationCountry" class="form-label lux-cap mb-1 small"></label>
                            <input asp-for="LocationCountry" class="lux-input w-100" placeholder="Việt Nam">
                        </div>
                </div>
            </section>

            <!-- SAVE BUTTON: covers Section 1 + Section 2 -->
            <div class="d-flex justify-content-end mb-5">
                <button type="submit" class="lux-btn-primary px-5 py-3 fs-6">
                    <i class="bi bi-save me-2"></i>Lưu tất cả thay đổi
                </button>
            </div>
            </form>

            <!-- ===== SECTION 3: SOCIAL ACCOUNTS ===== -->
            <section id="section-social" class="lux-surface p-4 mb-4" data-reveal="fade-up">
                <h5 class="lux-cap text-gold mb-4"><i class="bi bi-share me-2"></i>Kết nối mạng xã hội</h5>

                @if (socialAccounts.Any())
                {
                    <div class="row g-3 mb-4">
                        @foreach (var sa in socialAccounts)
                        {
                            <div class="col-md-6">
                                <div class="ep-social-card d-flex align-items-center gap-3 p-3 rounded-3 border">
                                    <div class="ep-platform-icon">
                                        @{
                                            var icon = sa.Platform?.ToLower() switch {
                                                "facebook" => "bi-facebook",
                                                "instagram" => "bi-instagram",
                                                "tiktok" => "bi-tiktok",
                                                "youtube" => "bi-youtube",
                                                "twitter" or "x" => "bi-twitter-x",
                                                "linkedin" => "bi-linkedin",
                                                _ => "bi-globe"
                                            };
                                        }
                                        <i class="bi @icon fs-4"></i>
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="fw-semibold small">@sa.Platform</div>
                                        <a href="@sa.ProfileUrl" target="_blank" class="text-muted small text-truncate d-block" style="max-width:180px;">@sa.ProfileUrl</a>
                                        @if (sa.Followers.HasValue)
                                        {
                                            <div class="text-gold small"><i class="bi bi-people me-1"></i>@sa.Followers.Value.ToString("N0")</div>
                                        }
                                    </div>
                                    <form asp-action="RemoveSocialAccount" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@sa.Id">
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-1" title="Xóa"
                                                onclick="return confirm('Xóa tài khoản này?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-4"><i class="bi bi-info-circle me-1"></i>Chưa có tài khoản mạng xã hội nào được liên kết.</p>
                }

                <!-- Add Social Account Form -->
                <div class="ep-add-panel p-4 rounded-3 border border-dashed">
                    <div class="lux-cap text-muted small mb-3"><i class="bi bi-plus-circle me-2"></i>Thêm tài khoản mới</div>
                    <form asp-action="AddSocialAccount" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-4">
                                <select name="Platform" class="lux-input w-100" required>
                                    <option value="">Nền tảng...</option>
                                    <option value="Facebook">Facebook</option>
                                    <option value="Instagram">Instagram</option>
                                    <option value="TikTok">TikTok</option>
                                    <option value="YouTube">YouTube</option>
                                    <option value="Twitter">Twitter / X</option>
                                    <option value="LinkedIn">LinkedIn</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                            <div class="col-md-5">
                                <input name="Url" type="url" class="lux-input w-100" placeholder="https://..." required>
                            </div>
                            <div class="col-md-3">
                                <input name="FollowersCount" type="number" min="0" class="lux-input w-100" placeholder="Followers">
                            </div>
                            <div class="col-12 d-flex justify-content-end">
                                <button type="submit" class="lux-btn-outline-gold px-4">
                                    <i class="bi bi-plus me-2"></i>Thêm
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </section>

            <!-- ===== SECTION 4: PORTFOLIO ===== -->
            <section id="section-portfolio" class="lux-surface p-4 mb-4" data-reveal="fade-up">
                <h5 class="lux-cap text-gold mb-4"><i class="bi bi-images me-2"></i>Portfolio Highlight</h5>
                <p class="text-muted small mb-4">Trình bày các dự án, ảnh hoặc video nổi bật của bạn. Thương hiệu sẽ xem phần này đầu tiên.</p>

                @if (portfolios.Any())
                {
                    <div class="row g-3 mb-4">
                        @foreach (var pf in portfolios)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="ep-portfolio-card position-relative rounded-3 overflow-hidden" style="aspect-ratio:1;">
                                    @if (!string.IsNullOrEmpty(pf.MediaUrl))
                                    {
                                        <img src="@pf.MediaUrl" alt="@pf.Title"
                                             class="w-100 h-100" style="object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark text-muted">
                                            <i class="bi bi-image fs-1"></i>
                                        </div>
                                    }
                                    <div class="ep-portfolio-overlay position-absolute bottom-0 start-0 end-0 p-2">
                                        <div class="text-white fw-semibold small text-truncate">@pf.Title</div>
                                    </div>
                                    <!-- Delete button -->
                                    <form asp-action="DeletePortfolio" method="post"
                                          class="position-absolute top-0 end-0 m-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@pf.Id">
                                        <button type="submit" class="btn btn-sm btn-dark rounded-circle opacity-85"
                                                title="Xóa" onclick="return confirm('Xóa ảnh portfolio này?')"
                                                style="width:28px;height:28px;padding:0;">
                                            <i class="bi bi-x" style="font-size:.8rem;"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-4"><i class="bi bi-info-circle me-1"></i>Chưa có ảnh portfolio nào. Hãy thêm để gây ấn tượng với thương hiệu!</p>
                }

                <!-- Add Portfolio Form -->
                <div class="ep-add-panel p-4 rounded-3 border border-dashed">
                    <div class="lux-cap text-muted small mb-3"><i class="bi bi-plus-circle me-2"></i>Thêm ảnh / tác phẩm</div>
                    <form asp-action="AddPortfolio" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input name="Title" class="lux-input w-100" placeholder="Tiêu đề tác phẩm *" required>
                            </div>
                            <div class="col-md-6">
                                <input name="ImageFile" type="file" accept="image/*,video/*"
                                       class="form-control lux-input" required>
                                <div class="form-text text-muted small">JPG, PNG, WEBP, GIF — tối đa 10MB</div>
                            </div>
                            <div class="col-12">
                                <input name="Description" class="lux-input w-100" placeholder="Mô tả ngắn (không bắt buộc)">
                            </div>
                            <div class="col-12 d-flex justify-content-end">
                                <button type="submit" class="lux-btn-outline-gold px-4">
                                    <i class="bi bi-plus me-2"></i>Thêm vào Portfolio
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </section>

            <!-- ===== SECTION 5: SERVICES & RATE CARDS ===== -->
            <section id="section-services" class="lux-surface p-4 mb-4" data-reveal="fade-up">
                <h5 class="lux-cap text-gold mb-4"><i class="bi bi-tags me-2"></i>Dịch vụ & Bảng giá</h5>

                @if (rateCards.Any())
                {
                    <div class="row g-3 mb-4">
                        @foreach (var rc in rateCards)
                        {
                            <div class="col-md-6">
                                <div class="p-3 rounded-3 border" style="border-left:3px solid var(--lux-accent-gold)!important;">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <div class="fw-semibold">@rc.Title</div>
                                        <span class="badge @(rc.IsActive == true ? "bg-success" : "bg-secondary")">
                                            @(rc.IsActive == true ? "Hoạt động" : "Ẩn")
                                        </span>
                                    </div>
                                    <div class="text-muted small">@rc.RateCardItems.Count() dịch vụ trong gói</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="p-4 rounded-3 border text-center text-muted mb-4">
                        <i class="bi bi-tags display-6 d-block mb-2 opacity-25"></i>
                        Bạn chưa có gói dịch vụ nào. Tạo bảng giá để thương hiệu dễ dàng đặt lịch hợp tác!
                    </div>
                }

                <a asp-action="RateCard" asp-controller="CreatorStudio" class="lux-btn-primary">
                    <i class="bi bi-pencil-square me-2"></i>Quản lý Bảng giá
                </a>
            </section>

        </div><!-- end right column -->
    </div><!-- end row -->
</div>

@section Scripts {
<style>
    /* Section navigation pills */
    .ep-nav-link {
        display: block;
        padding: .45rem .8rem;
        border-radius: 8px;
        font-size: .8rem;
        font-weight: 500;
        color: var(--lux-text-secondary, #aaa);
        text-decoration: none;
        transition: all .2s;
    }
    .ep-nav-link:hover, .ep-nav-link.active {
        background: rgba(201,168,76,.12);
        color: var(--lux-accent-gold, #C9A84C);
    }

    /* Social card */
    .ep-social-card {
        background: rgba(255,255,255,.03);
        border-color: rgba(255,255,255,.08) !important;
        transition: border-color .2s;
    }
    .ep-social-card:hover { border-color: var(--lux-accent-gold,.5) !important; }

    .ep-platform-icon {
        width: 44px; height: 44px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(201,168,76,.1);
        border-radius: 12px;
        color: var(--lux-accent-gold);
        flex-shrink: 0;
    }

    /* Portfolio card */
    .ep-portfolio-card { background: #1a1c2c; }
    .ep-portfolio-overlay {
        background: linear-gradient(transparent, rgba(0,0,0,.8));
        padding: .5rem !important;
    }
    .ep-portfolio-card:hover img { transform: scale(1.04); transition: .3s; }

    /* Add panel */
    .ep-add-panel {
        background: rgba(255,255,255,.02);
        border-style: dashed !important;
        border-color: rgba(201,168,76,.3) !important;
    }

    /* Responsive sticky nav */
    @@media (max-width: 991px) {
        .sticky-top { position: relative !important; top: 0 !important; }
    }
</style>
<script>
    function updateAvatarPreview(url) {
        // kept for compat
    }
    function previewAvatar(input) {
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('avatarPreview').src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

        // Highlight active nav link on scroll
        const sections = document.querySelectorAll('section[id^="section-"]');
        const navLinks = document.querySelectorAll('.ep-nav-link');
        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(s => {
                if (window.scrollY >= s.offsetTop - 150) current = s.id;
            });
            navLinks.forEach(link => {
                link.classList.toggle('active', link.getAttribute('href') === '#' + current);
            });
        });
    });
</script>
}
