@model List<KOL_KOC_TAAA.ViewModels.BrandLogoViewModel>

<section class="lux-brands py-5" style="background: var(--lux-bg-stone); border-top: 1px solid rgba(0,0,0,0.04);">
    <div class="container overflow-hidden">
        <div class="text-center mb-4" data-reveal="fade-up">
            <span class="text-uppercase fw-bold small ls-2" style="color: var(--lux-accent-gold); font-size:.65rem; letter-spacing:2px;">Đối tác tiêu biểu</span>
            <div class="fs-5 fw-semibold mt-2" style="color: var(--lux-primary-indigo);">Đồng hành cùng <span style="color: var(--lux-accent-gold);">thương hiệu hàng đầu</span></div>
        </div>

        <div class="d-flex flex-wrap justify-content-center align-items-center gap-4 gap-md-5">
            @{
                var brandIcons = new Dictionary<string, string> {
                    {"Samsung", "bi-phone"},
                    {"Unilever", "bi-globe2"},
                    {"Shopee", "bi-bag"},
                    {"Lazada", "bi-cart3"},
                    {"Grab", "bi-car-front"},
                    {"TikTok", "bi-tiktok"},
                    {"Vinamilk", "bi-cup-hot"},
                    {"VinGroup", "bi-building"},
                    {"L'Oréal", "bi-stars"}
                };
            }
            @foreach (var brand in Model)
            {
                var icon = brandIcons.ContainsKey(brand.Name) ? brandIcons[brand.Name] : "bi-building";
                <div class="brand-logo-item d-flex align-items-center gap-2 px-3 py-2" data-reveal="fade-in">
                    <i class="bi @icon" style="font-size:1.2rem;"></i>
                    <span class="fw-bold" style="font-size:.95rem; letter-spacing:-.02em;">@brand.Name</span>
                </div>
            }
        </div>
    </div>
</section>

<style>
    .brand-logo-item {
        color: var(--lux-text-dim);
        opacity: .55;
        transition: all .35s ease;
        border-radius: 8px;
        cursor: default;
    }
    .brand-logo-item:hover {
        opacity: 1;
        color: var(--lux-primary-indigo);
        background: rgba(0,0,0,0.03);
    }
</style>
