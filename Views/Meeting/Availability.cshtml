@model KOL_KOC_TAAA.ViewModels.KolAvailabilityViewModel
@{
    Layout = "_LayoutLuxury";
    ViewData["Title"] = "Quản lý lịch rảnh";

    var year = Model.Year;
    var month = Model.Month;
    var firstDay = new DateTime(year, month, 1);
    var daysInMonth = DateTime.DaysInMonth(year, month);
    // 0=Sun,1=Mon,...6=Sat — shift to Mon-first grid
    var startDow = (int)firstDay.DayOfWeek; // 0=Sun
    var offset = startDow == 0 ? 6 : startDow - 1; // 0=Mon in grid

    var prevMonth = month == 1 ? 12 : month - 1;
    var prevYear  = month == 1 ? year - 1 : year;
    var nextMonth = month == 12 ? 1 : month + 1;
    var nextYear  = month == 12 ? year + 1 : year;

    // Build a HashSet of busy dates for the displayed month
    var busyDays = new Dictionary<int, List<string>>(); // day -> list of booking titles
    var today = DateOnly.FromDateTime(DateTime.Today);

    foreach (var r in Model.BookingRanges)
    {
        if (r.StartDate == null || r.EndDate == null) continue;
        if (r.Status == "completed" || r.Status == "paid" || r.Status == "closed" || r.Status == "rejected" || r.Status == "canceled") continue;
        
        var s = r.StartDate.Value;
        var e = r.EndDate.Value;
        for (var d = s; d <= e; d = d.AddDays(1))
        {
            if (d.Year == year && d.Month == month)
            {
                if (!busyDays.ContainsKey(d.Day))
                    busyDays[d.Day] = new List<string>();
                busyDays[d.Day].Add(r.Title);
            }
        }
    }

    string[] dayNames = { "T2", "T3", "T4", "T5", "T6", "T7", "CN" };
    string[] monthNames = { "", "Tháng 1", "Tháng 2", "Tháng 3", "Tháng 4", "Tháng 5", "Tháng 6",
        "Tháng 7", "Tháng 8", "Tháng 9", "Tháng 10", "Tháng 11", "Tháng 12" };

    string StatusBadge(string status) => status switch {
        "accepted" => "badge bg-success",
        "active_contract" => "badge bg-primary",
        "rejected" => "badge bg-danger",
        "completed" => "badge bg-secondary",
        _ => "badge bg-warning text-dark"
    };
    string StatusLabel(string status) => status switch {
        "accepted" => "Đã chấp nhận",
        "active_contract" => "Đang hợp tác",
        "rejected" => "Từ chối",
        "completed" => "Hoàn thành",
        _ => "Chờ duyệt"
    };
}

<style>
    .availability-page { min-height: 100vh; padding: 2rem 0; }
    .page-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
    .page-title { color: #1e293b; font-size: 1.5rem; font-weight: 700; letter-spacing: .5px; }
    .page-title i { color: #c9a84c; }

    /* Calendar */
    .cal-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .cal-month { color: #1e293b; font-size: 1.2rem; font-weight: 600; }
    .cal-btn { background: #f8f9fa; border: 1px solid #e5e7eb; color: #6366f1; border-radius: 8px;
               padding: .4rem .9rem; cursor: pointer; text-decoration: none; transition: all .2s; font-weight: 500; }
    .cal-btn:hover { background: #6366f1; color: #fff; border-color: #6366f1; }

    .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; }
    .cal-header { color: #94a3b8; font-size: .75rem; font-weight: 600; text-align: center; padding: .5rem 0; text-transform: uppercase; letter-spacing: .5px; }
    .cal-cell { min-height: 75px; border-radius: 10px; padding: 6px 8px; position: relative; cursor: default; transition: all .2s; }
    .cal-cell.empty { background: transparent; }
    .cal-cell.free { background: #f8f9fa; border: 1px solid #e5e7eb; }
    .cal-cell.free:hover { border-color: #6366f1; background: #f0f0ff; }
    .cal-cell.busy { background: #fef2f2; border: 1px solid #fca5a5; }
    .cal-cell.busy:hover { background: #fee2e2; }
    .cal-cell.today-cell { outline: 2px solid #c9a84c; outline-offset: -1px; }
    .cal-day-num { font-size: .8rem; font-weight: 600; color: #475569; }
    .cal-cell.busy .cal-day-num { color: #dc2626; }
    .cal-cell.today-cell .cal-day-num { color: #c9a84c; font-weight: 700; }
    .cal-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%;
               background: #ef4444; margin-top: 4px; }
    .cal-booking-label { font-size: .65rem; color: #dc2626; line-height: 1.2; margin-top: 2px;
                         overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }

    /* Legend */
    .legend { display: flex; gap: 1.5rem; align-items: center; margin-bottom: 1.5rem; }
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: .8rem; color: #64748b; }
    .legend-box { width: 18px; height: 18px; border-radius: 4px; }
    .legend-box.free  { background: #f8f9fa; border: 1px solid #e5e7eb; }
    .legend-box.busy  { background: #fef2f2; border: 1px solid #fca5a5; }
    .legend-box.today { outline: 2px solid #c9a84c; background: #f8f9fa; }

    /* Sidebar stats */
    .stat-label { color: #64748b; font-size: .85rem; }
    .stat-section-title { color: #94a3b8; font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: .75rem; }

    /* Table */
    .bookings-table { width: 100%; border-collapse: separate; border-spacing: 0 6px; }
    .bookings-table thead th { color: #94a3b8; font-size: .75rem; text-transform: uppercase;
                                letter-spacing: .5px; padding: .5rem 1rem; border-bottom: 1px solid #e5e7eb; }
    .bookings-table tbody tr { background: #f8f9fa; transition: background .2s; }
    .bookings-table tbody tr:hover { background: #f0f0ff; }
    .bookings-table td { padding: .75rem 1rem; color: #475569; font-size: .85rem; }
    .bookings-table td:first-child { border-radius: 10px 0 0 10px; }
    .bookings-table td:last-child  { border-radius: 0 10px 10px 0; }
    .empty-state { text-align: center; padding: 3rem; color: #94a3b8; }
    .empty-state i { font-size: 3rem; display: block; margin-bottom: 1rem; color: #cbd5e1; }
    .section-title { color: #1e293b; font-weight: 700; font-size: 1.1rem; }
    .section-title i { color: #c9a84c; }
</style>

<div class="availability-page">
    <div class="container">
        <div class="d-flex align-items-center mb-4 gap-3">
            <a asp-controller="CreatorStudio" asp-action="Index" class="cal-btn">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="page-title mb-0"><i class="bi bi-calendar3 me-2"></i>Quản lý lịch rảnh</h1>
        </div>

        <div class="row g-4">
            <!-- Calendar -->
            <div class="col-lg-8">
                <div class="page-card">
                    <div class="cal-nav">
                        <a asp-action="Availability" asp-route-year="@prevYear" asp-route-month="@prevMonth" class="cal-btn">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                        <span class="cal-month">@monthNames[month] @year</span>
                        <a asp-action="Availability" asp-route-year="@nextYear" asp-route-month="@nextMonth" class="cal-btn">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>

                    <div class="legend">
                        <div class="legend-item"><div class="legend-box free"></div> Rảnh</div>
                        <div class="legend-item"><div class="legend-box busy"></div> Bận (có booking)</div>
                        <div class="legend-item"><div class="legend-box today"></div> Hôm nay</div>
                    </div>

                    <div class="cal-grid">
                        @foreach (var dn in dayNames)
                        {
                            <div class="cal-header">@dn</div>
                        }

                        @* Empty cells before day 1 *@
                        @for (int i = 0; i < offset; i++)
                        {
                            <div class="cal-cell empty"></div>
                        }

                        @for (int d = 1; d <= daysInMonth; d++)
                        {
                            var isBusy = busyDays.ContainsKey(d);
                            var isToday = today.Year == year && today.Month == month && today.Day == d;
                            var cellClass = "cal-cell " + (isBusy ? "busy" : "free") + (isToday ? " today-cell" : "");
                            <div class="@cellClass">
                                <div class="cal-day-num">@d</div>
                                @if (isBusy)
                                {
                                    <div class="cal-dot"></div>
                                    @foreach (var t in busyDays[d].Take(2))
                                    {
                                        <div class="cal-booking-label">@t</div>
                                    }
                                    @if (busyDays[d].Count > 2)
                                    {
                                        <div class="cal-booking-label" style="color:#ff6b6b">+@(busyDays[d].Count - 2) nữa</div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Stats sidebar -->
            <div class="col-lg-4">
                <div class="page-card mb-3">
                    <div class="stat-section-title">Tổng quan lịch</div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="stat-label">Tổng booking</span>
                        <span class="text-dark fw-bold">@Model.BookingRanges.Count</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="stat-label">Đang hợp tác</span>
                        <span class="text-primary fw-bold">@Model.BookingRanges.Count(r => r.Status == "active_contract")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="stat-label">Đã chấp nhận</span>
                        <span class="text-success fw-bold">@Model.BookingRanges.Count(r => r.Status == "accepted")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="stat-label">Chờ duyệt</span>
                        <span class="text-warning fw-bold">@Model.BookingRanges.Count(r => r.Status == "sent")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="stat-label">Ngày bận tháng này</span>
                        <span class="text-danger fw-bold">@busyDays.Count</span>
                    </div>
                </div>

                <div class="page-card">
                    <div class="stat-section-title">Tháng này</div>
                    @{
                        var thisMonthRanges = Model.BookingRanges
                            .Where(r => r.StartDate != null && r.EndDate != null &&
                                        r.EndDate.Value.Year >= year && r.StartDate.Value.Year <= year &&
                                        r.EndDate.Value.Month >= month && r.StartDate.Value.Month <= month)
                            .ToList();
                    }
                    @if (!thisMonthRanges.Any())
                    {
                        <p class="text-muted small mb-0">Không có booking nào trong tháng này.</p>
                    }
                    else
                    {
                        @foreach (var r in thisMonthRanges.Take(5))
                        {
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <div style="width:8px;height:8px;border-radius:50%;background:#ef4444;flex-shrink:0;margin-top:6px"></div>
                                <div>
                                    <div class="text-dark" style="font-size:.8rem;font-weight:600">@r.Title</div>
                                    <div class="text-muted" style="font-size:.72rem">@r.StartDate?.ToString("dd/MM") – @r.EndDate?.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                        }
                        @if (thisMonthRanges.Count > 5)
                        {
                            <div class="text-muted" style="font-size:.75rem">+@(thisMonthRanges.Count - 5) booking khác...</div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- All bookings table -->
        <div class="page-card mt-4">
            <h5 class="section-title" style="margin-bottom:1.5rem"><i class="bi bi-list-check me-2"></i>Tất cả booking của bạn</h5>

            @if (!Model.BookingRanges.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-calendar-x"></i>
                    <div>Chưa có yêu cầu booking nào.</div>
                    <a asp-controller="CreatorStudio" asp-action="Index" class="btn btn-outline-secondary btn-sm mt-3">Về trang Studio</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="bookings-table">
                        <thead>
                            <tr>
                                <th>Công việc</th>
                                <th>Khách hàng</th>
                                <th>Bắt đầu</th>
                                <th>Kết thúc</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.BookingRanges)
                            {
                                <tr>
                                    <td style="font-weight:600;color:#1e293b">@r.Title</td>
                                    <td>@r.CustomerName</td>
                                    <td>@(r.StartDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                    <td>@(r.EndDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                    <td><span class="@StatusBadge(r.Status)">@StatusLabel(r.Status)</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
